{
  "name": "doitoo-games",
  "version": "1.0.0",
  "private": true,
  "description": "Doitoo Games — a multi-game launcher platform",
  "scripts": {
    "serve": "npx http-server . -p 8080 -c-1",
    "serve:dist": "npx http-server dist -p 8080 -c-1",
    "serve:doitoo-numbers": "cd games/doitoo-numbers && npm start",
    "build:doitoo-numbers": "cd games/doitoo-numbers && npm run build",
    "build:games": "npm run build:doitoo-numbers",
    "build:platform": "node scripts/build.js",
    "build": "npm run build:games && npm run build:platform"
  },
  "devDependencies": {
    "fast-check": "^3.22.0",
    "http-server": "^14.1.1"
  }
}
